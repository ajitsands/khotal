// URL Encryption & Security Configuration
define('ENCRYPTION_KEY', 'your_encryption_key_here'); // Keep secret
define('ENCRYPTION_METHOD', 'aes-256-cbc');

// GitHub Webhook Configuration (used by webhook.php for sync)
define('WEBHOOK_SECRET', 'your_webhook_secret_here');
